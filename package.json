{
  "name": "blog",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "dev": "pnpm --parallel --filter backend --filter frontend run dev",
    "dev:backend": "pnpm --filter backend dev",
